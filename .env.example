# Token bota od @BotFather na Telegramie
TELEGRAM_BOT_TOKEN=tutaj_wklej_token

# Chat ID - do kogo bot ma wysylac wiadomosci
# (napisz do @userinfobot na Telegramie zeby poznac swoje ID)
TELEGRAM_CHAT_ID=tutaj_wklej_chat_id

# Godzina codziennej wysylki (format: HH:MM, domyslnie 07:00)
DAILY_SEND_HOUR=07
DAILY_SEND_MINUTE=00
